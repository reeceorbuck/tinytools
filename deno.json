{
  "name": "@tiny-tools/hono",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./jsx-runtime": "./jsx-runtime.ts",
    "./build": "./build.ts",
    "./components": "./components/mod.ts",
    "./client": "./client/mod.ts"
  },
  "tasks": {
    "build:client": "deno run -A buildClientFiles.ts",
    "test": "deno test --check --allow-env --allow-read=./.test-build-output --allow-read=./.test-client-src --allow-write=./.test-build-output --allow-write=./.test-client-src --allow-run tests/"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "esbuild": "npm:esbuild@^0.27.1",
    "hono": "jsr:@hono/hono@^4.0.10"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@tiny-tools/hono",
    "lib": [
      "esnext",
      "deno.ns",
      "deno.unstable",
      "dom",
      "dom.iterable",
      "dom.asynciterable"
    ]
  },
  "publish": {
    "include": [
      "mod.ts",
      "jsx-runtime.ts",
      "build.ts",
      "types.ts",
      "clientFunctions.ts",
      "scopedStyles.ts",
      "honoFactory.ts",
      "components/**/*.ts",
      "components/**/*.tsx",
      "client/**/*.ts",
      "client/dist/**/*.js",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*.test.ts"
    ]
  }
}
