{
  "name": "@tinytools/hono-tools",
  "description": "A lightweight enhancement layer for Hono web applications. Provides type-safe client functions, scoped styles, and enhanced JSX event handlers. Works with Deno, Bun, and Node.js.",
  "version": "0.1.24",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./jsx-runtime": "./jsx-runtime.ts",
    "./jsx-dev-runtime": "./jsx-dev-runtime.ts",
    "./build": "./build.ts",
    "./components": "./components/mod.ts",
    "./client": "./client/mod.ts",
    "./globals": "./globals.d.ts"
  },
  "tasks": {
    "build:client": "deno run -A buildClientFiles.ts",
    "prepublish": "cd .. && deno task bump patch && cd package && deno task build:client && deno publish --allow-slow-types --allow-dirty",
    "npm:publish": "deno task build:client && npm publish --access public",
    "test": "deno test --check --allow-env --allow-read=./.test-build-output --allow-read=./.test-client-src --allow-read=./client/dist --allow-write=./.test-build-output --allow-write=./.test-client-src --allow-write=./public/styles --allow-write=./public/handlers --allow-run tests/"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "hono": "jsr:@hono/hono@^4.12.12"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "lib": [
      "esnext",
      "deno.ns",
      "dom",
      "dom.iterable",
      "dom.asynciterable"
    ]
  },
  "publish": {
    "include": [
      "mod.ts",
      "titled.ts",
      "jsx-runtime.ts",
      "jsx-dev-runtime.ts",
      "build.ts",
      "esbuildInit.ts",
      "clientFunctions.ts",
      "clientTools.ts",
      "scopedStyles.ts",
      "honoFactory.tsx",
      "sendUpdates.tsx",
      "sse.ts",
      "startupPerformanceSummary.ts",
      "components/**/*.ts",
      "components/**/*.tsx",
      "client/**/*.ts",
      "client/dist/**/*.js",
      "globals.d.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*.test.ts"
    ]
  }
}
